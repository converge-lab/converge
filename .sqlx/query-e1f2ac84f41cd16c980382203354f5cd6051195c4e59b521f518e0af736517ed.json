  "db_name": "PostgreSQL",
  "query": "select id, project_id,\n                      case when exists (select 1 from decision_supersedes s\n                                        where s.supersedes_id = d.id)\n                           then 'superseded'::decision_status\n                           else d.status\n                      end as \"status!: _\",\n                      title, summary, context, consequences, alternatives, captured_at\n               from decisions d\n               where d.id = $1",
