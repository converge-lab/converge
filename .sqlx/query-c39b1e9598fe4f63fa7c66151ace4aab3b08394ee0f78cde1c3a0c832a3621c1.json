  "query": "select id, project_id, kind as \"kind: _\", external, title, captured_at\n               from sessions\n               where ($1::uuid is null or project_id = $1)\n                 and ($2::session_kind is null or kind = $2)\n                 and ($4::uuid is null or id < $4)\n               order by id desc\n               limit $3",
