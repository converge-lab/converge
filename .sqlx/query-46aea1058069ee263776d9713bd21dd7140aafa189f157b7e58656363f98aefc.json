  "query": "select id, session_id, seq, speaker, body, sent_at, captured_at\n               from messages\n               where session_id = $1\n                 and ($2::uuid is null\n                      or seq > (select seq from messages where id = $2 and session_id = $1))\n               order by seq\n               limit $3",
